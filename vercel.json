{
  "version": 2,
  "builds": [
    {
      "src": "langlearn_config/wsgi.py",
      "use": "@vercel/python",
      "config": {
        "maxLambdaSize": "15mb",
        "runtime": "python3.12"
      }
    }
  ],
  "routes": [
    {
      "src": "/static/(.*)",
      "dest": "/staticfiles/$1"
    },
    {
      "src": "/favicon.png",
      "dest": "/static/favicon.svg"
    },
    {
      "src": "/favicon.ico",
      "dest": "/static/favicon.svg"
    },
    {
      "src": "/(.*)",
      "dest": "langlearn_config/wsgi.py"
    }
  ]
}