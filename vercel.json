{
  "version": 2,
  "builds": [
    {
      "src": "langlearn_config/wsgi.py",
      "use": "@vercel/python",
      "config": {
        "maxLambdaSize": "15mb",
        "runtime": "python3.12",
        "middleware": "langlearn_config/wsgi.py"
      }
    }
  ],
  "env": {
    "PYTHON_VERSION": "3.12"
  },
  "routes": [
    {
      "src": "/static/(.*)",
      "dest": "/static/$1"
    },
    {
      "src": "/(.*)",
      "dest": "langlearn_config/wsgi.py"
    }
  ]
}
